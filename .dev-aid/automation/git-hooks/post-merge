#!/bin/bash
# Dev-AID post-merge hook
# Auto-detect and optionally resolve merge conflicts
#
# To install this hook:
#   ln -s $(pwd)/.dev-aid/automation/git-hooks/post-merge .git/hooks/post-merge
#   chmod +x .git/hooks/post-merge
#
# To enable auto-resolution:
#   export DEV_AID_AUTO_RESOLVE=true

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m' # No Color

# Check for conflicts
if git ls-files -u | grep -q .; then
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${RED}🔥 Merge conflicts detected!${NC}"
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo

    # Show conflicted files
    echo -e "${YELLOW}Conflicted files:${NC}"
    git ls-files -u | cut -f2 | sort -u | while read -r file; do
        echo "  - $file"
    done
    echo

    # Check if auto-resolution is enabled
    if [ "${DEV_AID_AUTO_RESOLVE:-false}" = "true" ]; then
        echo -e "${BLUE}🤖 Auto-resolution enabled${NC}"
        echo -e "${CYAN}Running dev-aid-fix-conflicts...${NC}"

        # Check if dev-aid-fix-conflicts is available
        if command -v dev-aid-fix-conflicts &> /dev/null; then
            dev-aid-fix-conflicts --auto --strategy smart
        else
            # Try to run from .dev-aid/scripts
            SCRIPT_DIR="$(dirname "$0")"
            if [ -x "$SCRIPT_DIR/../../../.dev-aid/scripts/dev-aid-fix-conflicts" ]; then
                "$SCRIPT_DIR/../../../.dev-aid/scripts/dev-aid-fix-conflicts" --auto --strategy smart
            else
                echo -e "${RED}❌ dev-aid-fix-conflicts not found${NC}"
                echo -e "${YELLOW}Please install Dev-AID or add .dev-aid/scripts to PATH${NC}"
                exit 1
            fi
        fi
    else
        echo -e "${GREEN}💡 Tip: Run 'dev-aid-fix-conflicts' to resolve automatically${NC}"
        echo -e "${GREEN}   Or set DEV_AID_AUTO_RESOLVE=true for automatic resolution${NC}"
        echo
        echo -e "${CYAN}Example:${NC}"
        echo -e "  ${BOLD}dev-aid-fix-conflicts${NC}                    # Interactive mode"
        echo -e "  ${BOLD}dev-aid-fix-conflicts --strategy smart${NC}   # Smart merge strategy"
        echo -e "  ${BOLD}dev-aid-fix-conflicts --dry-run${NC}          # Preview resolution"
    fi

    exit 1
fi

exit 0

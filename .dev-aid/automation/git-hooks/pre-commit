#!/usr/bin/env bash
# Dev-AID Pre-Commit Hook - Fast Security Checks
# Runs critical security scans before allowing commit (~10 seconds)

set -euo pipefail

# Colors
readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly BLUE='\033[0;34m'
readonly NC='\033[0m'

# Temp files tracking
declare -a TEMP_FILES=()

# Cleanup handler
cleanup() {
    local exit_code=$?

    # Clean up temp files securely
    for temp_file in "${TEMP_FILES[@]}"; do
        if [[ -f "$temp_file" ]]; then
            if command -v shred >/dev/null 2>&1; then
                shred -u "$temp_file" 2>/dev/null || rm -f "$temp_file"
            else
                rm -f "$temp_file"
            fi
        fi
    done

    exit "$exit_code"
}

trap cleanup EXIT INT TERM

log_info() { echo -e "${BLUE}[PRE-COMMIT]${NC} $1"; }
log_success() { echo -e "${GREEN}[PRE-COMMIT]${NC} $1"; }
log_warning() { echo -e "${YELLOW}[PRE-COMMIT]${NC} $1"; }
log_error() { echo -e "${RED}[PRE-COMMIT]${NC} $1"; }

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
log_info "Running fast security checks..."
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

ISSUES_FOUND=0
START_TIME=$(date +%s)

# Check 1: Secret Scanning with Gitleaks
log_info "1/3 Scanning for secrets..."
if command -v gitleaks &> /dev/null; then
    if gitleaks detect --no-git --verbose --exit-code 1 2>&1 | grep -q "leaks found"; then
        log_error "❌ SECRETS DETECTED! Review and remove before committing."
        ISSUES_FOUND=$((ISSUES_FOUND + 1))
    else
        log_success "✓ No secrets found"
    fi
else
    log_error "❌ Gitleaks not installed - security check cannot run"
    log_info "Install: brew install gitleaks (or see https://github.com/gitleaks/gitleaks#installing)"
    ISSUES_FOUND=$((ISSUES_FOUND + 1))
fi
echo ""

# Check 2: SAST with Opengrep (Comprehensive rulesets, ERROR severity)
log_info "2/3 Scanning code for critical vulnerabilities..."
OPENGREP_CMD="opengrep"
[[ -f "$HOME/.local/bin/opengrep" ]] && OPENGREP_CMD="$HOME/.local/bin/opengrep"

if command -v $OPENGREP_CMD &> /dev/null; then
    # Create temp file for results
    OPENGREP_OUT=$(mktemp)
    chmod 600 "$OPENGREP_OUT"
    TEMP_FILES+=("$OPENGREP_OUT")

    # Scan with comprehensive rulesets (340+ rules), ERROR severity only for speed
    # Rulesets: default, security-audit, secrets, ci, cwe-top-25
    if $OPENGREP_CMD scan \
        --config p/default \
        --config p/security-audit \
        --config p/secrets \
        --severity ERROR \
        --json --output "$OPENGREP_OUT" . 2>/dev/null; then
        # Check if any findings
        FINDINGS=$(jq -r '.results | length' "$OPENGREP_OUT" 2>/dev/null || echo "0")
        if [[ "$FINDINGS" -gt 0 ]]; then
            log_error "❌ $FINDINGS critical security issue(s) found!"
            log_info "Run: opengrep scan --config p/security-audit ."
            ISSUES_FOUND=$((ISSUES_FOUND + 1))
        else
            log_success "✓ No critical vulnerabilities (scanned with 340+ rules)"
        fi
    else
        log_success "✓ No critical vulnerabilities found"
    fi
else
    log_warning "⚠️  Opengrep not installed (skipping SAST)"
    log_info "Install: curl -fsSL https://raw.githubusercontent.com/opengrep/opengrep/main/install.sh | bash"
fi
echo ""

# Check 3: Trivy - CVE + Misconfig Scanning (Critical only for speed)
log_info "3/3 Scanning for CVEs and misconfigurations..."
if command -v trivy &> /dev/null; then
    # Create temp file for results
    TRIVY_OUT=$(mktemp)
    chmod 600 "$TRIVY_OUT"
    TEMP_FILES+=("$TRIVY_OUT")

    # Scan with vuln + misconfig + secret scanners, CRITICAL severity for speed
    if trivy fs \
        --scanners vuln,misconfig,secret \
        --severity CRITICAL \
        --format json \
        --output "$TRIVY_OUT" \
        --quiet . 2>/dev/null; then
        # Check for findings
        VULNS=$(jq -r '[.Results[]?.Vulnerabilities[]?] | length' "$TRIVY_OUT" 2>/dev/null || echo "0")
        MISCONFIGS=$(jq -r '[.Results[]?.Misconfigurations[]?] | length' "$TRIVY_OUT" 2>/dev/null || echo "0")
        SECRETS=$(jq -r '[.Results[]?.Secrets[]?] | length' "$TRIVY_OUT" 2>/dev/null || echo "0")

        if [[ "$VULNS" -gt 0 ]] || [[ "$SECRETS" -gt 0 ]]; then
            log_error "❌ Critical issues: $VULNS CVEs, $SECRETS secrets, $MISCONFIGS misconfigs"
            log_info "Run: trivy fs --scanners vuln,misconfig,secret ."
            ISSUES_FOUND=$((ISSUES_FOUND + 1))
        elif [[ "$MISCONFIGS" -gt 0 ]]; then
            log_warning "⚠️  $MISCONFIGS misconfiguration(s) found (non-blocking)"
        else
            log_success "✓ No critical CVEs, secrets, or misconfigs"
        fi
    else
        log_success "✓ No critical issues found"
    fi
else
    log_error "❌ Trivy not installed - security check cannot run"
    log_info "Install: brew install trivy (or see https://aquasecurity.github.io/trivy/latest/getting-started/installation/)"
    ISSUES_FOUND=$((ISSUES_FOUND + 1))
fi
echo ""

# Summary
END_TIME=$(date +%s)
DURATION=$((END_TIME - START_TIME))

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
if [[ $ISSUES_FOUND -eq 0 ]]; then
    log_success "✓ All checks passed! (${DURATION}s)"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    exit 0
else
    log_error "✗ $ISSUES_FOUND issue(s) found (${DURATION}s)"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    log_warning "Fix the issues above or bypass with: git commit --no-verify"
    echo ""
    exit 1
fi

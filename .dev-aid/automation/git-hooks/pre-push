#!/usr/bin/env bash
# Dev-AID Pre-Push Hook - Thorough Security Checks
# Runs comprehensive security scans before pushing (~60 seconds)

set -euo pipefail

# Colors
readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly BLUE='\033[0;34m'
readonly NC='\033[0m'

# Temp files tracking
declare -a TEMP_FILES=()

# Cleanup handler
cleanup() {
    local exit_code=$?

    # Clean up temp files securely
    for temp_file in "${TEMP_FILES[@]}"; do
        if [[ -f "$temp_file" ]]; then
            if command -v shred >/dev/null 2>&1; then
                shred -u "$temp_file" 2>/dev/null || rm -f "$temp_file"
            else
                rm -f "$temp_file"
            fi
        fi
    done

    exit "$exit_code"
}

trap cleanup EXIT INT TERM

log_info() { echo -e "${BLUE}[PRE-PUSH]${NC} $1"; }
log_success() { echo -e "${GREEN}[PRE-PUSH]${NC} $1"; }
log_warning() { echo -e "${YELLOW}[PRE-PUSH]${NC} $1"; }
log_error() { echo -e "${RED}[PRE-PUSH]${NC} $1"; }

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
log_info "Running comprehensive security checks..."
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

ISSUES_FOUND=0
WARNINGS_FOUND=0
START_TIME=$(date +%s)

# Check 1: Secret Scanning (Full git history)
log_info "1/3 Scanning for secrets (including git history)..."
if command -v gitleaks &> /dev/null; then
    GITLEAKS_OUT=$(mktemp)
    chmod 600 "$GITLEAKS_OUT"
    TEMP_FILES+=("$GITLEAKS_OUT")

    if gitleaks detect --verbose --report-path "$GITLEAKS_OUT" --exit-code 1 2>&1; then
        log_success "✓ No secrets found"
    else
        LEAKS_COUNT=$(jq -r 'length' "$GITLEAKS_OUT" 2>/dev/null || echo "unknown")
        log_error "❌ $LEAKS_COUNT secret(s) detected!"
        log_info "Details: $GITLEAKS_OUT"
        ISSUES_FOUND=$((ISSUES_FOUND + 1))
    fi
else
    log_warning "⚠️  Gitleaks not installed"
    WARNINGS_FOUND=$((WARNINGS_FOUND + 1))
fi
echo ""

# Check 2: SAST with Opengrep (Comprehensive + language-aware rulesets)
log_info "2/3 Running static code analysis..."
OPENGREP_CMD="opengrep"
[[ -f "$HOME/.local/bin/opengrep" ]] && OPENGREP_CMD="$HOME/.local/bin/opengrep"

if command -v $OPENGREP_CMD &> /dev/null; then
    OPENGREP_OUT=$(mktemp)
    chmod 600 "$OPENGREP_OUT"
    TEMP_FILES+=("$OPENGREP_OUT")

    # Build ruleset list: universal + auto-detected language-specific
    OPENGREP_CONFIGS=(
        # Universal security rulesets
        "--config" "p/default"           # Semgrep curated defaults
        "--config" "p/security-audit"    # Comprehensive security patterns
        "--config" "p/secrets"           # Hardcoded credentials
        "--config" "p/ci"               # CI/CD security (GitHub Actions, etc)
        "--config" "p/cwe-top-25"        # MITRE CWE Top 25 vulnerabilities
        "--config" "p/owasp-top-ten"     # OWASP Top 10 categories
        "--config" "p/trailofbits"       # Professional security audit rules (Trail of Bits)
        "--config" "p/command-injection" # Command injection across languages
        "--config" "p/insecure-transport" # HTTP where HTTPS expected
        "--config" "p/jwt"               # JWT misconfigurations
    )

    # Auto-detect languages and add language-specific rulesets
    DETECTED_LANGS=""
    if find . -name '*.py' -not -path '*/venv/*' -not -path '*/.venv/*' -not -path '*/.git/*' -print -quit 2>/dev/null | grep -q .; then
        OPENGREP_CONFIGS+=("--config" "p/python")
        DETECTED_LANGS="${DETECTED_LANGS} Python"
    fi
    if find . -name '*.js' -o -name '*.jsx' -not -path '*/node_modules/*' -not -path '*/.git/*' 2>/dev/null | head -1 | grep -q .; then
        OPENGREP_CONFIGS+=("--config" "p/javascript")
        DETECTED_LANGS="${DETECTED_LANGS} JS"
    fi
    if find . -name '*.ts' -o -name '*.tsx' -not -path '*/node_modules/*' -not -path '*/.git/*' 2>/dev/null | head -1 | grep -q .; then
        OPENGREP_CONFIGS+=("--config" "p/typescript")
        DETECTED_LANGS="${DETECTED_LANGS} TS"
    fi
    if find . -name '*.go' -not -path '*/.git/*' -print -quit 2>/dev/null | grep -q .; then
        OPENGREP_CONFIGS+=("--config" "p/golang")
        DETECTED_LANGS="${DETECTED_LANGS} Go"
    fi
    if find . -name '*.rs' -not -path '*/.git/*' -print -quit 2>/dev/null | grep -q .; then
        OPENGREP_CONFIGS+=("--config" "p/rust")
        DETECTED_LANGS="${DETECTED_LANGS} Rust"
    fi
    if find . -name '*.swift' -not -path '*/.git/*' -print -quit 2>/dev/null | grep -q .; then
        OPENGREP_CONFIGS+=("--config" "p/swift")
        DETECTED_LANGS="${DETECTED_LANGS} Swift"
    fi
    if find . -name '*.java' -not -path '*/.git/*' -print -quit 2>/dev/null | grep -q .; then
        OPENGREP_CONFIGS+=("--config" "p/java")
        DETECTED_LANGS="${DETECTED_LANGS} Java"
    fi
    if find . -name '*.kt' -not -path '*/.git/*' -print -quit 2>/dev/null | grep -q .; then
        OPENGREP_CONFIGS+=("--config" "p/kotlin")
        DETECTED_LANGS="${DETECTED_LANGS} Kotlin"
    fi
    if find . -name '*.rb' -not -path '*/.git/*' -print -quit 2>/dev/null | grep -q .; then
        OPENGREP_CONFIGS+=("--config" "p/ruby")
        DETECTED_LANGS="${DETECTED_LANGS} Ruby"
    fi
    if find . -name '*.php' -not -path '*/.git/*' -print -quit 2>/dev/null | grep -q .; then
        OPENGREP_CONFIGS+=("--config" "p/php")
        DETECTED_LANGS="${DETECTED_LANGS} PHP"
    fi
    if find . -name '*.cs' -not -path '*/.git/*' -print -quit 2>/dev/null | grep -q .; then
        OPENGREP_CONFIGS+=("--config" "p/csharp")
        DETECTED_LANGS="${DETECTED_LANGS} C#"
    fi
    if find . -name '*.scala' -not -path '*/.git/*' -print -quit 2>/dev/null | grep -q .; then
        OPENGREP_CONFIGS+=("--config" "p/scala")
        DETECTED_LANGS="${DETECTED_LANGS} Scala"
    fi

    RULESET_COUNT=${#OPENGREP_CONFIGS[@]}
    RULESET_COUNT=$((RULESET_COUNT / 2))  # Each ruleset is 2 elements: --config + name
    log_info "  Scanning with $RULESET_COUNT rulesets (detected:${DETECTED_LANGS:- none})"

    if $OPENGREP_CMD scan \
        "${OPENGREP_CONFIGS[@]}" \
        --json --output "$OPENGREP_OUT" . 2>/dev/null; then
        :  # Scan completed
    fi

    FINDINGS=$(jq -r '.results | length' "$OPENGREP_OUT" 2>/dev/null || echo "0")
    if [[ "$FINDINGS" -gt 0 ]]; then
        # Count by severity
        CRITICAL=$(jq -r '[.results[] | select(.extra.severity == "ERROR")] | length' "$OPENGREP_OUT" 2>/dev/null || echo "0")
        WARNINGS=$(jq -r '[.results[] | select(.extra.severity == "WARNING")] | length' "$OPENGREP_OUT" 2>/dev/null || echo "0")

        if [[ "$CRITICAL" -gt 0 ]]; then
            log_error "❌ $CRITICAL critical issue(s), $WARNINGS warning(s)"
            ISSUES_FOUND=$((ISSUES_FOUND + 1))
        else
            log_warning "⚠️  $WARNINGS warning(s) found"
            WARNINGS_FOUND=$((WARNINGS_FOUND + 1))
        fi

        log_info "Run: opengrep scan --config p/security-audit . | less"
    else
        log_success "✓ No issues found ($RULESET_COUNT rulesets)"
    fi
else
    log_warning "⚠️  Opengrep not installed"
    log_info "Install: curl -fsSL https://raw.githubusercontent.com/opengrep/opengrep/main/install.sh | bash"
    WARNINGS_FOUND=$((WARNINGS_FOUND + 1))
fi
echo ""

# Check 3: Trivy - Comprehensive Scanning (CVE + Misconfig + Secrets)
log_info "3/3 Scanning for vulnerabilities, misconfigs, and secrets..."
if command -v trivy &> /dev/null; then
    TRIVY_OUT=$(mktemp)
    chmod 600 "$TRIVY_OUT"
    TEMP_FILES+=("$TRIVY_OUT")

    # Comprehensive scan with all scanners, HIGH and CRITICAL severities
    trivy fs \
        --scanners vuln,misconfig,secret \
        --severity HIGH,CRITICAL \
        --format json \
        --output "$TRIVY_OUT" . 2>/dev/null || true

    # Count findings by type
    VULNS=$(jq -r '[.Results[]?.Vulnerabilities[]?] | length' "$TRIVY_OUT" 2>/dev/null || echo "0")
    MISCONFIGS=$(jq -r '[.Results[]?.Misconfigurations[]?] | length' "$TRIVY_OUT" 2>/dev/null || echo "0")
    SECRETS=$(jq -r '[.Results[]?.Secrets[]?] | length' "$TRIVY_OUT" 2>/dev/null || echo "0")

    # Count by severity
    CRITICAL_VULNS=$(jq -r '[.Results[]?.Vulnerabilities[]? | select(.Severity == "CRITICAL")] | length' "$TRIVY_OUT" 2>/dev/null || echo "0")
    HIGH_VULNS=$(jq -r '[.Results[]?.Vulnerabilities[]? | select(.Severity == "HIGH")] | length' "$TRIVY_OUT" 2>/dev/null || echo "0")
    CRITICAL_MISCONFIGS=$(jq -r '[.Results[]?.Misconfigurations[]? | select(.Severity == "CRITICAL")] | length' "$TRIVY_OUT" 2>/dev/null || echo "0")

    TOTAL_CRITICAL=$((CRITICAL_VULNS + CRITICAL_MISCONFIGS + SECRETS))
    TOTAL_HIGH=$((HIGH_VULNS))

    if [[ "$TOTAL_CRITICAL" -gt 0 ]]; then
        log_error "❌ Critical: $CRITICAL_VULNS CVEs, $CRITICAL_MISCONFIGS misconfigs, $SECRETS secrets"
        ISSUES_FOUND=$((ISSUES_FOUND + 1))
    elif [[ "$TOTAL_HIGH" -gt 0 ]] || [[ "$MISCONFIGS" -gt 0 ]]; then
        log_warning "⚠️  High: $HIGH_VULNS CVEs, $MISCONFIGS misconfigs"
        WARNINGS_FOUND=$((WARNINGS_FOUND + 1))
    else
        log_success "✓ No high/critical vulnerabilities, misconfigs, or secrets"
    fi

    if [[ "$VULNS" -gt 0 ]] || [[ "$MISCONFIGS" -gt 0 ]] || [[ "$SECRETS" -gt 0 ]]; then
        log_info "Run: trivy fs --scanners vuln,misconfig,secret ."
    fi
else
    log_warning "⚠️  Trivy not installed"
    log_info "Install: brew install trivy"
    WARNINGS_FOUND=$((WARNINGS_FOUND + 1))
fi
echo ""

# ── Language-Specific Security Checks ─────────────────────
log_info "Running language-specific security checks..."
LANG_CHECKS=0
LANG_ISSUES=0

# Bash/Shell: ShellCheck (SAST — injection, quoting, globbing attacks)
if find . -name '*.sh' -not -path '*/.git/*' -not -path '*/node_modules/*' -print -quit 2>/dev/null | grep -q .; then
    LANG_CHECKS=$((LANG_CHECKS + 1))

    if command -v shellcheck &> /dev/null; then
        log_info "[Shell] Running ShellCheck SAST analysis..."
        SHELLCHECK_OUT=$(mktemp)
        chmod 600 "$SHELLCHECK_OUT"
        TEMP_FILES+=("$SHELLCHECK_OUT")

        # Find all shell scripts, exclude common vendored paths
        SHELL_FILES=()
        while IFS= read -r -d '' f; do
            SHELL_FILES+=("$f")
        done < <(find . -name '*.sh' -not -path '*/.git/*' -not -path '*/node_modules/*' -not -path '*/venv/*' -not -path '*/.venv/*' -print0 2>/dev/null)

        if [[ ${#SHELL_FILES[@]} -gt 0 ]]; then
            if shellcheck -S warning -f json "${SHELL_FILES[@]}" > "$SHELLCHECK_OUT" 2>/dev/null; then
                log_success "✓ No shell script issues found (ShellCheck)"
            else
                SC_ERRORS=$(jq -r '[.[] | select(.level == "error")] | length' "$SHELLCHECK_OUT" 2>/dev/null || echo "0")
                SC_WARNINGS=$(jq -r '[.[] | select(.level == "warning")] | length' "$SHELLCHECK_OUT" 2>/dev/null || echo "0")

                if [[ "$SC_ERRORS" -gt 0 ]]; then
                    log_error "❌ Shell SAST: $SC_ERRORS error(s), $SC_WARNINGS warning(s)"
                    log_info "Run: shellcheck -S warning *.sh"
                    LANG_ISSUES=$((LANG_ISSUES + 1))
                else
                    log_warning "⚠️  Shell SAST: $SC_WARNINGS warning(s)"
                fi
            fi
        fi
    else
        log_warning "⚠️  ShellCheck not installed (Shell SAST skipped)"
        log_info "Install: brew install shellcheck"
    fi
fi

# C/C++: Flawfinder (SAST — CWE-mapped security scanner)
if find . \( -name '*.c' -o -name '*.h' -o -name '*.cpp' -o -name '*.cc' -o -name '*.cxx' -o -name '*.hpp' \) -not -path '*/.git/*' -not -path '*/node_modules/*' -print -quit 2>/dev/null | grep -q .; then
    LANG_CHECKS=$((LANG_CHECKS + 1))

    if command -v flawfinder &> /dev/null; then
        log_info "[C/C++] Running Flawfinder security analysis..."
        FLAWFINDER_OUT=$(mktemp)
        chmod 600 "$FLAWFINDER_OUT"
        TEMP_FILES+=("$FLAWFINDER_OUT")

        # --minlevel=2: medium+ severity, --dataonly: machine-parseable, --quiet: no progress
        if flawfinder --minlevel=2 --dataonly --quiet --csv . > "$FLAWFINDER_OUT" 2>/dev/null; then
            # Flawfinder exits 0 even with findings; check output line count
            FLAW_COUNT=$(wc -l < "$FLAWFINDER_OUT" | tr -d ' ')
            # Subtract header line if present
            if [[ "$FLAW_COUNT" -le 1 ]]; then
                log_success "✓ No C/C++ security issues found (Flawfinder)"
            else
                FLAW_COUNT=$((FLAW_COUNT - 1))
                log_error "❌ C/C++ SAST: $FLAW_COUNT issue(s) (CWE-mapped)"
                log_info "Run: flawfinder --minlevel=2 ."
                LANG_ISSUES=$((LANG_ISSUES + 1))
            fi
        else
            log_warning "⚠️  Flawfinder scan failed"
        fi
    else
        log_warning "⚠️  Flawfinder not installed (C/C++ SAST skipped)"
        log_info "Install: pipx install flawfinder"
    fi
fi

# Swift: mobsfscan (SAST — OWASP MASVS/MSTG mobile security patterns)
if find . -name '*.swift' -not -path '*/.git/*' -not -path '*/node_modules/*' -print -quit 2>/dev/null | grep -q .; then
    LANG_CHECKS=$((LANG_CHECKS + 1))

    if command -v mobsfscan &> /dev/null; then
        log_info "[Swift] Running mobsfscan security analysis..."
        MOBSF_OUT=$(mktemp)
        chmod 600 "$MOBSF_OUT"
        TEMP_FILES+=("$MOBSF_OUT")

        if mobsfscan --json -o "$MOBSF_OUT" . 2>/dev/null; then
            MOBSF_ISSUES=$(jq -r '.results | length' "$MOBSF_OUT" 2>/dev/null || echo "0")
            if [[ "$MOBSF_ISSUES" -eq 0 ]]; then
                log_success "✓ No Swift security issues found (mobsfscan)"
            else
                MOBSF_HIGH=$(jq -r '[.results[] | select(.issue_severity == "high")] | length' "$MOBSF_OUT" 2>/dev/null || echo "0")
                MOBSF_WARN=$(jq -r '[.results[] | select(.issue_severity == "warning")] | length' "$MOBSF_OUT" 2>/dev/null || echo "0")
                log_error "❌ Swift SAST: $MOBSF_HIGH high, $MOBSF_WARN warning(s)"
                log_info "Run: mobsfscan ."
                LANG_ISSUES=$((LANG_ISSUES + 1))
            fi
        else
            log_warning "⚠️  mobsfscan scan failed"
        fi
    else
        log_warning "⚠️  mobsfscan not installed (Swift SAST skipped)"
        log_info "Install: pipx install mobsfscan"
    fi
fi

# Python: Bandit (SAST) + pip-audit (dependency vulnerabilities)
if find . -name '*.py' -not -path '*/venv/*' -not -path '*/.venv/*' -not -path '*/node_modules/*' -not -path '*/__pycache__/*' -not -path '*/.git/*' -print -quit 2>/dev/null | grep -q .; then
    LANG_CHECKS=$((LANG_CHECKS + 1))

    # Bandit - Python SAST (medium+ severity)
    if command -v bandit &> /dev/null; then
        log_info "[Python] Running Bandit SAST analysis..."
        BANDIT_OUT=$(mktemp)
        chmod 600 "$BANDIT_OUT"
        TEMP_FILES+=("$BANDIT_OUT")

        if bandit -r . -ll -ii \
            --exclude '*/venv/*,*/.venv/*,*/node_modules/*,*/.git/*,*/__pycache__/*' \
            -f json -o "$BANDIT_OUT" 2>/dev/null; then
            log_success "✓ No Python security issues found (Bandit)"
        else
            BANDIT_ISSUES=$(jq -r '.results | length' "$BANDIT_OUT" 2>/dev/null || echo "0")
            BANDIT_HIGH=$(jq -r '[.results[] | select(.issue_severity == "HIGH")] | length' "$BANDIT_OUT" 2>/dev/null || echo "0")
            BANDIT_MEDIUM=$(jq -r '[.results[] | select(.issue_severity == "MEDIUM")] | length' "$BANDIT_OUT" 2>/dev/null || echo "0")

            if [[ "$BANDIT_ISSUES" -gt 0 ]]; then
                log_error "❌ Python SAST: $BANDIT_HIGH high, $BANDIT_MEDIUM medium issue(s)"
                log_info "Run: bandit -r . -ll --exclude '*/venv/*'"
                LANG_ISSUES=$((LANG_ISSUES + 1))
            fi
        fi
    else
        log_warning "⚠️  Bandit not installed (Python SAST skipped)"
        log_info "Install: pipx install bandit"
    fi

    # pip-audit - Python dependency vulnerabilities
    if [[ -f "requirements.txt" ]] || [[ -f "requirements-dev.txt" ]] || [[ -f "pyproject.toml" ]] || compgen -G "requirements*.txt" > /dev/null 2>&1; then
        if command -v pip-audit &> /dev/null; then
            log_info "[Python] Running pip-audit dependency check..."
            PIPAUDIT_OUT=$(mktemp)
            chmod 600 "$PIPAUDIT_OUT"
            TEMP_FILES+=("$PIPAUDIT_OUT")

            if pip-audit --desc -f json -o "$PIPAUDIT_OUT" 2>/dev/null; then
                log_success "✓ No Python dependency vulnerabilities (pip-audit)"
            else
                PIPAUDIT_VULNS=$(jq -r '.dependencies | [.[] | select(.vulns | length > 0)] | length' "$PIPAUDIT_OUT" 2>/dev/null || echo "unknown")
                log_error "❌ Python deps: $PIPAUDIT_VULNS vulnerable package(s)"
                log_info "Run: pip-audit --desc"
                LANG_ISSUES=$((LANG_ISSUES + 1))
            fi
        else
            log_warning "⚠️  pip-audit not installed (Python dep scan skipped)"
            log_info "Install: pipx install pip-audit"
        fi
    fi
fi

# JavaScript/TypeScript: npm audit
if [[ -f "package-lock.json" ]] || [[ -f "yarn.lock" ]]; then
    LANG_CHECKS=$((LANG_CHECKS + 1))

    if command -v npm &> /dev/null; then
        log_info "[JS/TS] Running npm audit..."
        NPMAUDIT_OUT=$(mktemp)
        chmod 600 "$NPMAUDIT_OUT"
        TEMP_FILES+=("$NPMAUDIT_OUT")

        if npm audit --audit-level=high --json > "$NPMAUDIT_OUT" 2>/dev/null; then
            log_success "✓ No high+ JS/TS dependency vulnerabilities (npm audit)"
        else
            NPM_VULNS=$(jq -r '.metadata.vulnerabilities.high // 0' "$NPMAUDIT_OUT" 2>/dev/null || echo "0")
            NPM_CRIT=$(jq -r '.metadata.vulnerabilities.critical // 0' "$NPMAUDIT_OUT" 2>/dev/null || echo "0")
            log_error "❌ JS/TS deps: $NPM_CRIT critical, $NPM_VULNS high vulnerability(ies)"
            log_info "Run: npm audit"
            LANG_ISSUES=$((LANG_ISSUES + 1))
        fi
    else
        log_warning "⚠️  npm not installed (JS/TS dep scan skipped)"
    fi
fi

# Rust: cargo audit
if [[ -f "Cargo.lock" ]]; then
    LANG_CHECKS=$((LANG_CHECKS + 1))

    if command -v cargo-audit &> /dev/null || command -v cargo &> /dev/null; then
        log_info "[Rust] Running cargo audit..."
        CARGOAUDIT_OUT=$(mktemp)
        chmod 600 "$CARGOAUDIT_OUT"
        TEMP_FILES+=("$CARGOAUDIT_OUT")

        if cargo audit --json > "$CARGOAUDIT_OUT" 2>/dev/null; then
            log_success "✓ No Rust dependency vulnerabilities (cargo audit)"
        else
            CARGO_VULNS=$(jq -r '.vulnerabilities.found' "$CARGOAUDIT_OUT" 2>/dev/null || echo "unknown")
            log_error "❌ Rust deps: $CARGO_VULNS vulnerability(ies) found"
            log_info "Run: cargo audit"
            LANG_ISSUES=$((LANG_ISSUES + 1))
        fi
    else
        log_warning "⚠️  cargo-audit not installed (Rust dep scan skipped)"
        log_info "Install: cargo install cargo-audit"
    fi
fi

# Go: govulncheck
if [[ -f "go.mod" ]]; then
    LANG_CHECKS=$((LANG_CHECKS + 1))

    if command -v govulncheck &> /dev/null; then
        log_info "[Go] Running govulncheck..."
        GOVULN_OUT=$(mktemp)
        chmod 600 "$GOVULN_OUT"
        TEMP_FILES+=("$GOVULN_OUT")

        if govulncheck -json ./... > "$GOVULN_OUT" 2>/dev/null; then
            log_success "✓ No Go vulnerabilities found (govulncheck)"
        else
            log_error "❌ Go vulnerabilities found"
            log_info "Run: govulncheck ./..."
            LANG_ISSUES=$((LANG_ISSUES + 1))
        fi
    else
        log_warning "⚠️  govulncheck not installed (Go vuln scan skipped)"
        log_info "Install: go install golang.org/dl/govulncheck@latest"
    fi
fi

if [[ $LANG_CHECKS -eq 0 ]]; then
    log_info "No language-specific checks applicable"
else
    if [[ $LANG_ISSUES -eq 0 ]]; then
        log_success "✓ All language-specific checks passed ($LANG_CHECKS language(s) scanned)"
    else
        log_error "✗ $LANG_ISSUES language-specific issue(s) found"
        ISSUES_FOUND=$((ISSUES_FOUND + LANG_ISSUES))
    fi
fi
echo ""

# Summary
END_TIME=$(date +%s)
DURATION=$((END_TIME - START_TIME))

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
if [[ $ISSUES_FOUND -eq 0 ]]; then
    if [[ $WARNINGS_FOUND -gt 0 ]]; then
        log_success "✓ No critical issues (${WARNINGS_FOUND} warnings) (${DURATION}s)"
    else
        log_success "✓ All checks passed! (${DURATION}s)"
    fi
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    exit 0
else
    log_error "✗ $ISSUES_FOUND critical issue(s), $WARNINGS_FOUND warning(s) (${DURATION}s)"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    log_warning "Fix the issues above or bypass with: git push --no-verify"
    echo ""
    exit 1
fi

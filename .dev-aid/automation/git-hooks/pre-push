#!/usr/bin/env bash
# Dev-AID Pre-Push Hook - Thorough Security Checks
# Runs comprehensive security scans before pushing (~60 seconds)

set -euo pipefail

# Colors
readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly BLUE='\033[0;34m'
readonly NC='\033[0m'

# Temp files tracking
declare -a TEMP_FILES=()

# Cleanup handler
cleanup() {
    local exit_code=$?

    # Clean up temp files securely
    for temp_file in "${TEMP_FILES[@]}"; do
        if [[ -f "$temp_file" ]]; then
            if command -v shred >/dev/null 2>&1; then
                shred -u "$temp_file" 2>/dev/null || rm -f "$temp_file"
            else
                rm -f "$temp_file"
            fi
        fi
    done

    exit "$exit_code"
}

trap cleanup EXIT INT TERM

log_info() { echo -e "${BLUE}[PRE-PUSH]${NC} $1"; }
log_success() { echo -e "${GREEN}[PRE-PUSH]${NC} $1"; }
log_warning() { echo -e "${YELLOW}[PRE-PUSH]${NC} $1"; }
log_error() { echo -e "${RED}[PRE-PUSH]${NC} $1"; }

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
log_info "Running comprehensive security checks..."
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

ISSUES_FOUND=0
WARNINGS_FOUND=0
START_TIME=$(date +%s)

# Check 1: Secret Scanning (Full git history)
log_info "1/3 Scanning for secrets (including git history)..."
if command -v gitleaks &> /dev/null; then
    GITLEAKS_OUT=$(mktemp)
    chmod 600 "$GITLEAKS_OUT"
    TEMP_FILES+=("$GITLEAKS_OUT")

    if gitleaks detect --verbose --report-path "$GITLEAKS_OUT" --exit-code 1 2>&1; then
        log_success "✓ No secrets found"
    else
        LEAKS_COUNT=$(jq -r 'length' "$GITLEAKS_OUT" 2>/dev/null || echo "unknown")
        log_error "❌ $LEAKS_COUNT secret(s) detected!"
        log_info "Details: $GITLEAKS_OUT"
        ISSUES_FOUND=$((ISSUES_FOUND + 1))
    fi
else
    log_warning "⚠️  Gitleaks not installed"
    WARNINGS_FOUND=$((WARNINGS_FOUND + 1))
fi
echo ""

# Check 2: SAST with Opengrep (Comprehensive rulesets, 340+ rules)
log_info "2/3 Running static code analysis (340+ security rules)..."
OPENGREP_CMD="opengrep"
[[ -f "$HOME/.local/bin/opengrep" ]] && OPENGREP_CMD="$HOME/.local/bin/opengrep"

if command -v $OPENGREP_CMD &> /dev/null; then
    OPENGREP_OUT=$(mktemp)
    chmod 600 "$OPENGREP_OUT"
    TEMP_FILES+=("$OPENGREP_OUT")

    # Scan with comprehensive rulesets (340+ rules):
    # - p/default: Semgrep curated defaults
    # - p/security-audit: Comprehensive security patterns
    # - p/secrets: Hardcoded credentials
    # - p/ci: CI/CD security (GitHub Actions, etc)
    # - p/cwe-top-25: MITRE CWE Top 25 vulnerabilities
    if $OPENGREP_CMD scan \
        --config p/default \
        --config p/security-audit \
        --config p/secrets \
        --config p/ci \
        --config p/cwe-top-25 \
        --json --output "$OPENGREP_OUT" . 2>/dev/null; then
        :  # Scan completed
    fi

    FINDINGS=$(jq -r '.results | length' "$OPENGREP_OUT" 2>/dev/null || echo "0")
    if [[ "$FINDINGS" -gt 0 ]]; then
        # Count by severity
        CRITICAL=$(jq -r '[.results[] | select(.extra.severity == "ERROR")] | length' "$OPENGREP_OUT" 2>/dev/null || echo "0")
        WARNINGS=$(jq -r '[.results[] | select(.extra.severity == "WARNING")] | length' "$OPENGREP_OUT" 2>/dev/null || echo "0")

        if [[ "$CRITICAL" -gt 0 ]]; then
            log_error "❌ $CRITICAL critical issue(s), $WARNINGS warning(s)"
            ISSUES_FOUND=$((ISSUES_FOUND + 1))
        else
            log_warning "⚠️  $WARNINGS warning(s) found"
            WARNINGS_FOUND=$((WARNINGS_FOUND + 1))
        fi

        log_info "Run: opengrep scan --config p/security-audit . | less"
    else
        log_success "✓ No issues found (scanned with 340+ rules)"
    fi
else
    log_warning "⚠️  Opengrep not installed"
    log_info "Install: curl -fsSL https://raw.githubusercontent.com/opengrep/opengrep/main/install.sh | bash"
    WARNINGS_FOUND=$((WARNINGS_FOUND + 1))
fi
echo ""

# Check 3: Trivy - Comprehensive Scanning (CVE + Misconfig + Secrets)
log_info "3/3 Scanning for vulnerabilities, misconfigs, and secrets..."
if command -v trivy &> /dev/null; then
    TRIVY_OUT=$(mktemp)
    chmod 600 "$TRIVY_OUT"
    TEMP_FILES+=("$TRIVY_OUT")

    # Comprehensive scan with all scanners, HIGH and CRITICAL severities
    trivy fs \
        --scanners vuln,misconfig,secret \
        --severity HIGH,CRITICAL \
        --format json \
        --output "$TRIVY_OUT" . 2>/dev/null || true

    # Count findings by type
    VULNS=$(jq -r '[.Results[]?.Vulnerabilities[]?] | length' "$TRIVY_OUT" 2>/dev/null || echo "0")
    MISCONFIGS=$(jq -r '[.Results[]?.Misconfigurations[]?] | length' "$TRIVY_OUT" 2>/dev/null || echo "0")
    SECRETS=$(jq -r '[.Results[]?.Secrets[]?] | length' "$TRIVY_OUT" 2>/dev/null || echo "0")

    # Count by severity
    CRITICAL_VULNS=$(jq -r '[.Results[]?.Vulnerabilities[]? | select(.Severity == "CRITICAL")] | length' "$TRIVY_OUT" 2>/dev/null || echo "0")
    HIGH_VULNS=$(jq -r '[.Results[]?.Vulnerabilities[]? | select(.Severity == "HIGH")] | length' "$TRIVY_OUT" 2>/dev/null || echo "0")
    CRITICAL_MISCONFIGS=$(jq -r '[.Results[]?.Misconfigurations[]? | select(.Severity == "CRITICAL")] | length' "$TRIVY_OUT" 2>/dev/null || echo "0")

    TOTAL_CRITICAL=$((CRITICAL_VULNS + CRITICAL_MISCONFIGS + SECRETS))
    TOTAL_HIGH=$((HIGH_VULNS))

    if [[ "$TOTAL_CRITICAL" -gt 0 ]]; then
        log_error "❌ Critical: $CRITICAL_VULNS CVEs, $CRITICAL_MISCONFIGS misconfigs, $SECRETS secrets"
        ISSUES_FOUND=$((ISSUES_FOUND + 1))
    elif [[ "$TOTAL_HIGH" -gt 0 ]] || [[ "$MISCONFIGS" -gt 0 ]]; then
        log_warning "⚠️  High: $HIGH_VULNS CVEs, $MISCONFIGS misconfigs"
        WARNINGS_FOUND=$((WARNINGS_FOUND + 1))
    else
        log_success "✓ No high/critical vulnerabilities, misconfigs, or secrets"
    fi

    if [[ "$VULNS" -gt 0 ]] || [[ "$MISCONFIGS" -gt 0 ]] || [[ "$SECRETS" -gt 0 ]]; then
        log_info "Run: trivy fs --scanners vuln,misconfig,secret ."
    fi
else
    log_warning "⚠️  Trivy not installed"
    log_info "Install: brew install trivy"
    WARNINGS_FOUND=$((WARNINGS_FOUND + 1))
fi
echo ""

# Summary
END_TIME=$(date +%s)
DURATION=$((END_TIME - START_TIME))

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
if [[ $ISSUES_FOUND -eq 0 ]]; then
    if [[ $WARNINGS_FOUND -gt 0 ]]; then
        log_success "✓ No critical issues (${WARNINGS_FOUND} warnings) (${DURATION}s)"
    else
        log_success "✓ All checks passed! (${DURATION}s)"
    fi
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    exit 0
else
    log_error "✗ $ISSUES_FOUND critical issue(s), $WARNINGS_FOUND warning(s) (${DURATION}s)"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    log_warning "Fix the issues above or bypass with: git push --no-verify"
    echo ""
    exit 1
fi

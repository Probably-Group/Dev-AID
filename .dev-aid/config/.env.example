# Dev-AID API Configuration
# Copy this file to .env and add your API keys
# cp .env.example .env

# ============================================
# AI PROVIDERS
# ============================================

# Anthropic (Claude)
# Get your key: https://console.anthropic.com/
# Note: If using Claude Code CLI, you may already be authenticated via session
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Google (Gemini)
# Get your key: https://aistudio.google.com/app/apikey
# Note: If using Gemini CLI, you may already be authenticated via gcloud
GOOGLE_API_KEY=your-google-api-key-here

# OpenAI (GPT)
# Get your key: https://platform.openai.com/api-keys
# IMPORTANT: ChatGPT Plus subscription does NOT include API access
# You must purchase separate API credits
OPENAI_API_KEY=your-openai-api-key-here

# ============================================
# API ROUTING (Optional)
# ============================================

# OpenRouter - Access 100+ models through one API
# Get your key: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here

# ============================================
# RESEARCH PROVIDERS (Optional)
# For deep research features
# ============================================

# Tavily - AI-powered search
# Get your key: https://tavily.com/
TAVILY_API_KEY=your-tavily-api-key-here

# Perplexity - AI search
# Get your key: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=your-perplexity-api-key-here

# ============================================
# LOCAL LLM PROVIDERS (Optional)
# For offline, private, zero-cost inference
# ============================================

# Local inference backend: ollama, lm_studio, or llama_cpp
LOCAL_INFERENCE_BACKEND=ollama

# Backend base URLs (defaults shown, change if using non-standard ports)
LOCAL_OLLAMA_URL=http://localhost:11434/v1
LOCAL_LM_STUDIO_URL=http://localhost:1234/v1
LOCAL_LLAMA_CPP_URL=http://localhost:8080/v1

# Default local model (optional - auto-detected based on hardware)
# Examples: phi4-mini, codestral:22b, qwen2.5-coder:32b
LOCAL_DEFAULT_MODEL=

# ============================================
# NOTES
# ============================================
#
# 1. You don't need ALL keys - just the providers you want to use
# 2. Claude and Gemini can use session auth from their CLI tools
#    (no API key needed if you're logged into Claude Code or Gemini CLI)
# 3. OpenAI requires API key (no session auth available)
# 4. Local LLMs require running backend (Ollama, LM Studio, or llama.cpp)
# 5. Never commit your .env file (it's in .gitignore)

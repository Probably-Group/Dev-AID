{
  "claude": {
    "enabled": true,
    "provider": "anthropic",
    "api_key_env": "ANTHROPIC_API_KEY",
    "models": {
      "sonnet-4.5": {
        "id": "claude-sonnet-4-5",
        "context_window": 200000,
        "capabilities": ["code", "analysis", "security", "reasoning"],
        "cost_per_1m_tokens": {
          "input": 3.00,
          "output": 15.00
        }
      },
      "opus-4.5": {
        "id": "claude-opus-4-5",
        "context_window": 200000,
        "capabilities": ["complex_reasoning", "deep_analysis", "architecture"],
        "cost_per_1m_tokens": {
          "input": 15.00,
          "output": 75.00
        }
      },
      "haiku-4.5": {
        "id": "claude-haiku-4-5",
        "context_window": 200000,
        "capabilities": ["speed", "simple_tasks", "quick_responses"],
        "cost_per_1m_tokens": {
          "input": 0.25,
          "output": 1.25
        }
      }
    },
    "default": "sonnet-4.5",
    "primary_capabilities": ["code", "analysis", "security"]
  },

  "gemini": {
    "enabled": false,
    "provider": "google",
    "api_key_env": "GOOGLE_API_KEY",
    "models": {
      "flash-2.0": {
        "id": "gemini-2.0-flash",
        "context_window": 1000000,
        "capabilities": ["massive_context", "fast_analysis", "multimodal"],
        "cost_per_1m_tokens": {
          "input": 0.075,
          "output": 0.30
        }
      },
      "pro-2.0": {
        "id": "gemini-2.0-pro",
        "context_window": 2000000,
        "capabilities": ["massive_context", "deep_reasoning", "multimodal"],
        "cost_per_1m_tokens": {
          "input": 1.25,
          "output": 5.00
        }
      }
    },
    "default": "flash-2.0",
    "primary_capabilities": ["massive_context", "analysis"]
  },

  "openai": {
    "enabled": false,
    "provider": "openai",
    "api_key_env": "OPENAI_API_KEY",
    "models": {
      "gpt-4-turbo": {
        "id": "gpt-4-turbo-2024-04-09",
        "context_window": 128000,
        "capabilities": ["general", "docs", "conversation"],
        "cost_per_1m_tokens": {
          "input": 10.00,
          "output": 30.00
        }
      },
      "gpt-4o": {
        "id": "gpt-4o",
        "context_window": 128000,
        "capabilities": ["general", "multimodal", "speed"],
        "cost_per_1m_tokens": {
          "input": 5.00,
          "output": 15.00
        }
      },
      "gpt-4.1": {
        "id": "gpt-4.1",
        "context_window": 1000000,
        "capabilities": ["general", "coding", "instruction_following", "massive_context"],
        "cost_per_1m_tokens": {
          "input": 5.00,
          "output": 15.00
        }
      },
      "gpt-3.5-turbo": {
        "id": "gpt-3.5-turbo",
        "context_window": 16385,
        "capabilities": ["simple_tasks", "speed", "low_cost"],
        "cost_per_1m_tokens": {
          "input": 0.50,
          "output": 1.50
        }
      }
    },
    "default": "gpt-4o",
    "primary_capabilities": ["general", "docs"]
  },

  "openrouter": {
    "enabled": false,
    "provider": "openrouter",
    "api_key_env": "OPENROUTER_API_KEY",
    "base_url": "https://openrouter.ai/api/v1",
    "models": {
      "auto": {
        "id": "openrouter/auto",
        "description": "Automatically routes to best available model",
        "capabilities": ["routing", "fallback"]
      }
    },
    "default": "auto",
    "primary_capabilities": ["routing", "fallback"]
  }
}

mode: solo
description: AI Model Orchestration Configuration
none:
  description: Manual mode - user explicitly chooses AI model for each task
  enabled: false
  note: No automatic routing. User has full control over model selection.
solo:
  description: Single default model handles all tasks
  model: claude-sonnet-4.5
  enabled: true
ensemble:
  description: Multiple models collaborate based on task capabilities
  enabled: false
  routing_strategy: capability_based
  capabilities:
    massive_context:
      description: "Large repository analysis, bulk file reading"
      model: gemini-2.0-flash
      triggers:
        file_count_gt: 50
        total_lines_gt: 10000
        context_tokens_gt: 100000
        keywords[3]: analyze entire,read all files,repository-wide
      fallback: claude-sonnet-4.5
    code_generation:
      description: Precise code generation and refactoring
      model: claude-sonnet-4.5
      triggers:
        task_type[4]: code,refactor,implement,fix
        tools_needed[3]: Read,Edit,Write
        file_extensions[5]: .ts,.js,.py,.go,.rs
      fallback: gpt-4o
    documentation:
      description: "Writing docs, READMEs, comments"
      model: gpt-4o
      triggers:
        task_type[4]: docs,readme,comments,explain
        file_extensions[3]: .md,.mdx,.txt
        keywords[3]: document,write readme,add comments
      fallback: claude-sonnet-4.5
    security_analysis:
      description: "Security audits, vulnerability detection"
      model: claude-sonnet-4.5
      triggers:
        task_type[3]: security,audit,vulnerabilities
        keywords[4]: security,vulnerability,owasp,audit
      fallback: gpt-4o
    quick_tasks:
      description: "Simple, fast responses"
      model: claude-haiku-4
      triggers:
        response_time_requirement: < 2s
        task_complexity: low
        keywords[3]: quick,simple,fast
      fallback: gpt-3.5-turbo
  chaining:
    enabled: true
    workflows:
      analyze_then_implement:
        description: Gemini analyzes → Claude implements
        steps[2]:
          - model: gemini-2.0-flash
            task: analyze
            output_to: context
          - model: claude-sonnet-4.5
            task: implement
            input_from: context
architect:
  description: "Two-agent pattern: Architect plans, Implementer executes"
  enabled: false
  optional: true
  architect_model: claude-opus-4.5
  implementer_model: claude-sonnet-4.5
  triggers:
    auto_activate:
      enabled: false
      conditions:
        estimated_file_changes_gt: 5
        keywords[5]: implement feature,build,create system,refactor,redesign
        complexity: high
    manual_activate:
      command: /architect
      description: User explicitly requests architect mode
  workflow:
    type: sequential
    steps[3]:
      - role: architect
        model: claude-opus-4.5
        task: analyze_and_plan
        output: implementation_plan
        focus[6]: Understand requirements fully,Identify affected files and components,Design approach with rationale,Define clear implementation steps,Identify risks and edge cases,Set success criteria
        constraints[3]: NO code writing - planning only,Must produce structured plan,Must identify all affected files
      - role: user_approval
        task: review_plan
        description: User reviews and approves the plan before implementation
        options[3]: approve,modify,reject
      - role: implementer
        model: claude-sonnet-4.5
        task: execute_plan
        input: implementation_plan
        focus[3]: Follow plan precisely,"Write clean, tested code",Report deviations if necessary
    fallback:
      on_architect_unavailable: solo_mode
      on_plan_rejected: revise_plan
  plan_format:
    required_sections[5]: ## Summary,## Affected Files,## Implementation Steps,## Success Criteria,## Risks & Mitigations
    optional_sections[3]: ## Alternative Approaches,## Dependencies,## Testing Strategy
challenger:
  description: "Primary model generates, challenger reviews"
  enabled: false
  primary_model: claude-sonnet-4.5
  challenger_model: gemini-2.0-pro
  challenge_triggers:
    security_sensitive:
      enabled: true
      patterns[5]: auth,password,token,secret,crypto
    performance_critical:
      enabled: true
      patterns[4]: query,loop,cache,optimization
    major_refactoring:
      enabled: true
      file_changes_gt: 100
    new_architecture:
      enabled: true
      keywords[4]: architecture,design,structure,framework
  workflow:
    type: sequential
    steps[3]:
      - role: primary
        model: claude-sonnet-4.5
        task: generate_solution
      - role: challenger
        model: gemini-2.0-pro
        task: review_and_critique
        focus[5]: Security vulnerabilities,Performance issues,Edge cases,Alternative approaches,Potential bugs
      - role: primary
        model: claude-sonnet-4.5
        task: revise_if_needed
        optional: true
    user_sees: both_perspectives
fallback_strategy:
  on_error: use_fallback_model
  on_rate_limit: queue_and_retry
  on_timeout: use_faster_model
  max_retries: 3
  retry_delay_seconds: 5
{
  "description": "Elite Claude Development Setup - Production-Ready Minimalist",
  "version": "1.0.0",
  "created": "2025-11-25",
  "architecture": "Balanced (~1,000 token standing context)",

  "enableAllProjectMcpServers": false,

  "permissions": {
    "_comment": "Claude Code v2.x permission syntax: 'Tool' for blanket allow, 'Tool(pattern)' for specific. The 'Tool:*' form does NOT exist and is silently ignored — early Dev-AID versions used it and beta testers got prompted on every command. Fixed in 1.5.1. WebSearch + WebFetch are required by /aid-research and the research agent.",
    "allow": [
      "Read",
      "Write",
      "Edit",
      "MultiEdit",
      "NotebookEdit",
      "Glob",
      "Grep",
      "Bash",
      "WebSearch",
      "WebFetch",
      "Task",
      "TodoWrite"
    ],
    "defaultMode": "acceptEdits"
  },

  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start-load-context.sh",
            "description": "Load memory bank foundation (~300 tokens)"
          }
        ]
      }
    ],

    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/skill-activation-conservative.sh",
            "description": "Conservative auto-load: file pattern matching, max 2-3 skills"
          }
        ]
      }
    ],

    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post-tool-use-tracker.sh",
            "description": "Track file modifications"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/lint-on-edit.sh",
            "description": "Auto-lint after Write/Edit"
          }
        ]
      }
    ],

    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/stop-quality-gates.sh",
            "description": "Quality gates + memory bank sync"
          }
        ]
      }
    ]
  },

  "comments": {
    "standing_context_budget": "~900-1,500 tokens (0.45-0.75% of 200k)",
    "auto_load_strategy": "Conservative: file pattern matching, max 2-3 skills",
    "architecture_pattern": "Balanced: orchestration + agents + commands",
    "duplicate_policy": "Zero duplicates - one tool per purpose",
    "token_efficiency": "99.25%+ tokens available for actual work"
  }
}

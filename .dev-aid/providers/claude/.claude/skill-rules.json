{
  "version": "1.0.0",
  "description": "Conservative Auto-Load Rules - File Pattern Matching",
  "created": "2025-11-25",
  "strategy": "Load max 2-3 skills when file patterns match with high confidence",

  "rules": [
    {
      "id": "testing-context",
      "confidence": "high",
      "trigger": {
        "files": ["*.test.*", "*.spec.*", "*test*.ts", "*test*.js", "__tests__/*", "tests/*"],
        "patterns": ["test", "testing", "TDD", "spec", "coverage", "jest", "vitest", "pytest"]
      },
      "skills": ["tdd-master"],
      "maxLoad": 1,
      "reason": "Testing file detected - load TDD skill for test-first development"
    },

    {
      "id": "security-context",
      "confidence": "high",
      "trigger": {
        "files": ["*auth*", "*login*", "*security*", "*crypto*", "*password*", "*.env*"],
        "patterns": ["security", "auth", "authentication", "authorization", "crypto", "password", "token", "secret"]
      },
      "skills": ["devsecops-expert", "owasp-guardian"],
      "maxLoad": 2,
      "reason": "Security-sensitive code detected - load security skills"
    },

    {
      "id": "database-context",
      "confidence": "high",
      "trigger": {
        "files": ["*migration*", "*schema*", "*model*", "*entity*", "*repository*"],
        "patterns": ["database", "query", "SQL", "migration", "schema", "ORM", "Prisma", "TypeORM"]
      },
      "skills": ["database-design"],
      "maxLoad": 1,
      "reason": "Database code detected - load database design skill"
    },

    {
      "id": "api-context",
      "confidence": "high",
      "trigger": {
        "files": ["*route*", "*controller*", "*endpoint*", "*api*", "*/routes/*", "*/controllers/*"],
        "patterns": ["API", "endpoint", "route", "controller", "REST", "GraphQL"]
      },
      "skills": ["api-expert", "backend-dev-guidelines"],
      "maxLoad": 2,
      "reason": "API code detected - load API and backend skills"
    },

    {
      "id": "frontend-context",
      "confidence": "high",
      "trigger": {
        "files": ["*.tsx", "*.jsx", "*component*", "*/components/*", "*/pages/*"],
        "patterns": ["React", "Vue", "Angular", "component", "useState", "useEffect"]
      },
      "skills": ["frontend-dev-guidelines"],
      "maxLoad": 1,
      "reason": "Frontend code detected - load frontend skill"
    },

    {
      "id": "performance-context",
      "confidence": "medium",
      "trigger": {
        "patterns": ["performance", "slow", "optimize", "bottleneck", "cache", "profiling"]
      },
      "skills": ["performance-expert"],
      "maxLoad": 1,
      "autoLoad": false,
      "reason": "Performance work mentioned - SUGGEST performance-expert skill"
    },

    {
      "id": "microservices-context",
      "confidence": "medium",
      "trigger": {
        "files": ["*service*", "*/services/*", "*microservice*"],
        "patterns": ["microservice", "service mesh", "distributed", "event-driven"]
      },
      "skills": ["microservices", "event-driven"],
      "maxLoad": 2,
      "autoLoad": false,
      "reason": "Microservices work - SUGGEST microservices skills"
    },

    {
      "id": "cicd-context",
      "confidence": "high",
      "trigger": {
        "files": [".github/workflows/*", ".gitlab-ci.yml", "Jenkinsfile", "*pipeline*"],
        "patterns": ["CI/CD", "pipeline", "deployment", "GitHub Actions", "GitLab CI"]
      },
      "skills": ["cicd-expert"],
      "maxLoad": 1,
      "reason": "CI/CD configuration detected - load cicd-expert"
    },

    {
      "id": "clean-code-context",
      "confidence": "medium",
      "trigger": {
        "patterns": ["refactor", "clean code", "SOLID", "design pattern", "code smell"]
      },
      "skills": ["clean-code", "design-patterns"],
      "maxLoad": 2,
      "autoLoad": false,
      "reason": "Clean code/refactoring - SUGGEST clean code skills"
    },

    {
      "id": "bash-scripting-context",
      "confidence": "high",
      "trigger": {
        "files": ["*.sh", "*.bash", "Dockerfile", "*/scripts/*", ".bashrc", ".bash_profile"],
        "patterns": ["bash", "shell script", "#!/bin/bash", "#!/usr/bin/env bash"]
      },
      "skills": ["bash-expert"],
      "maxLoad": 1,
      "reason": "Bash script detected - load bash-expert for secure scripting"
    }
  ],

  "config": {
    "maxSkillsPerPrompt": 3,
    "highConfidenceThreshold": 0.8,
    "autoLoadOnlyHighConfidence": true,
    "suggestMediumConfidence": true,
    "tokenBudget": {
      "perSkill": 200,
      "maximum": 600
    }
  },

  "alwaysLoaded": {
    "description": "Core skills loaded at SessionStart (configured in .dev-aid/config/core-skills.json)",
    "configFile": "../../config/core-skills.json",
    "availableSkills": {
      "code-reviewer": {
        "description": "Real-time code quality checks",
        "tokenBudget": 250,
        "recommendedFor": "all"
      },
      "secret-scanner": {
        "description": "Prevent credential leaks",
        "tokenBudget": 250,
        "recommendedFor": "all"
      },
      "test-runner": {
        "description": "Auto-run tests on file save",
        "tokenBudget": 250,
        "recommendedFor": "no-ide-setup"
      },
      "linter": {
        "description": "Auto-lint on file save",
        "tokenBudget": 250,
        "recommendedFor": "no-ide-setup"
      },
      "type-checker": {
        "description": "Auto-check types on file save",
        "tokenBudget": 250,
        "recommendedFor": "no-ide-setup"
      }
    },
    "defaultEnabled": ["code-reviewer", "secret-scanner"],
    "defaultTokenBudget": 500,
    "maximumTokenBudget": 1250,
    "configCommand": "/dev-aid-config-core-skills"
  }
}

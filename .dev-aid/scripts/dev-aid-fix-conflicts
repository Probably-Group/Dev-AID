#!/usr/bin/env python3
"""
dev-aid-fix-conflicts: Resolve merge conflicts in PRs using LLM

This script leverages Dev-AID's orchestration system to automatically:
1. Detect merge conflicts in a PR or current branch
2. Analyze both sides of the conflict
3. Generate a resolution using the configured LLM
4. Apply the resolution and create a commit

Usage:
    dev-aid-fix-conflicts [--pr <number>] [options]

Examples:
    # Resolve conflicts in current branch
    dev-aid-fix-conflicts

    # Resolve conflicts in a specific PR
    dev-aid-fix-conflicts --pr 67

    # Show proposed resolution without applying
    dev-aid-fix-conflicts --dry-run

    # Use specific strategy
    dev-aid-fix-conflicts --strategy smart

Security:
    - Validates all inputs using Pydantic models
    - Shows diff before applying changes
    - Requires confirmation before committing (unless --auto)
    - Runs tests after resolution to verify correctness
"""

import argparse
import json
import re
import subprocess
import sys
from pathlib import Path
from typing import Dict, List, Optional, Tuple

# Add orchestration to path
SCRIPT_DIR = Path(__file__).parent
ORCHESTRATION_DIR = SCRIPT_DIR.parent / "orchestration"
sys.path.insert(0, str(ORCHESTRATION_DIR))

try:
    from router.executor import execute_request
    from router.config_loader import ConfigLoader
except ImportError as e:
    print(f"❌ Error: Could not import Dev-AID orchestration modules: {e}", file=sys.stderr)
    print("   Make sure you're running from the Dev-AID repository root.", file=sys.stderr)
    sys.exit(1)

# Colors for output
class Colors:
    RED = '\033[0;31m'
    GREEN = '\033[0;32m'
    YELLOW = '\033[1;33m'
    BLUE = '\033[0;34m'
    MAGENTA = '\033[0;35m'
    CYAN = '\033[0;36m'
    BOLD = '\033[1m'
    NC = '\033[0m'  # No Color

def print_colored(message: str, color: str = Colors.NC):
    """Print colored message to stdout"""
    print(f"{color}{message}{Colors.NC}")

def print_error(message: str):
    """Print error message to stderr"""
    print(f"{Colors.RED}❌ {message}{Colors.NC}", file=sys.stderr)

def print_success(message: str):
    """Print success message"""
    print(f"{Colors.GREEN}✅ {message}{Colors.NC}")

def print_info(message: str):
    """Print info message"""
    print(f"{Colors.BLUE}ℹ️  {message}{Colors.NC}")

def print_warning(message: str):
    """Print warning message"""
    print(f"{Colors.YELLOW}⚠️  {message}{Colors.NC}")

def run_command(cmd: List[str], capture_output: bool = True, check: bool = True, cwd: Optional[str] = None) -> subprocess.CompletedProcess:
    """Run shell command with error handling"""
    try:
        result = subprocess.run(
            cmd,
            capture_output=capture_output,
            text=True,
            check=check,
            cwd=cwd
        )
        return result
    except subprocess.CalledProcessError as e:
        print_error(f"Command failed: {' '.join(cmd)}")
        if e.stderr:
            print(e.stderr, file=sys.stderr)
        raise
    except FileNotFoundError:
        print_error(f"Command not found: {cmd[0]}")
        raise

def detect_conflicts() -> List[str]:
    """Detect conflicted files using git"""
    result = run_command(
        ["git", "diff", "--name-only", "--diff-filter=U"],
        check=False
    )

    if result.returncode != 0:
        return []

    files = result.stdout.strip().split('\n') if result.stdout.strip() else []
    return [f for f in files if f]

def get_conflict_content(file_path: str) -> Optional[str]:
    """Read conflict markers from file"""
    try:
        with open(file_path, 'r') as f:
            content = f.read()

        # Check if file has conflict markers
        if '<<<<<<<' in content and '>>>>>>>' in content:
            return content
        return None
    except Exception as e:
        print_error(f"Could not read {file_path}: {e}")
        return None

def parse_conflicts(content: str) -> List[Dict[str, str]]:
    """Parse conflict markers into structured data"""
    conflicts = []
    lines = content.split('\n')
    i = 0

    while i < len(lines):
        line = lines[i]

        if line.startswith('<<<<<<<'):
            # Start of conflict
            conflict = {
                'marker_start': line,
                'ours': [],
                'theirs': [],
                'base': []
            }
            i += 1

            # Collect 'ours' lines
            while i < len(lines) and not lines[i].startswith('|||||||') and not lines[i].startswith('======='):
                conflict['ours'].append(lines[i])
                i += 1

            # Optional: base version (if using diff3)
            if i < len(lines) and lines[i].startswith('|||||||'):
                i += 1
                while i < len(lines) and not lines[i].startswith('======='):
                    conflict['base'].append(lines[i])
                    i += 1

            # Separator
            if i < len(lines) and lines[i].startswith('======='):
                i += 1

            # Collect 'theirs' lines
            while i < len(lines) and not lines[i].startswith('>>>>>>>'):
                conflict['theirs'].append(lines[i])
                i += 1

            # End marker
            if i < len(lines) and lines[i].startswith('>>>>>>>'):
                conflict['marker_end'] = lines[i]
                conflicts.append(conflict)

            i += 1
        else:
            i += 1

    return conflicts

def build_conflict_prompt(file_path: str, conflicts: List[Dict], strategy: str = "smart") -> str:
    """Build prompt for LLM to resolve conflicts"""

    conflict_details = []
    for idx, conflict in enumerate(conflicts, 1):
        ours = '\n'.join(conflict['ours'])
        theirs = '\n'.join(conflict['theirs'])

        conflict_details.append(f"""
### Conflict {idx}

**Current Branch (ours):**
```
{ours}
```

**Incoming Branch (theirs):**
```
{theirs}
```
""")

    all_conflicts = '\n'.join(conflict_details)

    strategy_instruction = {
        "smart": "Analyze both sides and create the optimal merge that preserves the intent of both changes",
        "ours": "Prefer the current branch's changes, but incorporate non-conflicting parts from incoming",
        "theirs": "Prefer the incoming branch's changes, but incorporate non-conflicting parts from current"
    }.get(strategy, "smart")

    prompt = f"""I need help resolving merge conflicts in the file: {file_path}

**Strategy:** {strategy}
{strategy_instruction}

**Conflicts to Resolve:**
{all_conflicts}

**Your Task:**
1. Analyze both versions and understand the intent of each change
2. Create a merged version that {strategy_instruction.lower()}
3. Ensure the merged code is syntactically correct
4. Explain your resolution decisions

**Important:**
- Remove ALL conflict markers (<<<<<<<, =======, >>>>>>>)
- Ensure the code follows the project's style
- Preserve functionality from both sides where possible
- If there's a genuine incompatibility, explain it

**Output Format:**
Please provide:
1. The complete resolved code (without conflict markers)
2. Explanation of how you resolved each conflict
3. Any concerns or trade-offs in your resolution

Provide the resolved code in a clean format without conflict markers.
"""
    return prompt

def apply_resolution(file_path: str, resolved_content: str) -> bool:
    """Apply the resolved content to the file"""
    try:
        with open(file_path, 'w') as f:
            f.write(resolved_content)
        return True
    except Exception as e:
        print_error(f"Failed to write resolved content to {file_path}: {e}")
        return False

def confirm_action(message: str, default: bool = False) -> bool:
    """Ask user for confirmation"""
    choices = "Y/n" if default else "y/N"
    response = input(f"{Colors.CYAN}❓ {message} [{choices}]: {Colors.NC}").strip().lower()

    if not response:
        return default

    return response in ['y', 'yes']

def check_pr_conflicts(pr_number: int) -> Tuple[bool, str]:
    """Check if a PR has conflicts"""
    try:
        result = run_command([
            "gh", "pr", "view", str(pr_number),
            "--json", "mergeable,mergeStateStatus"
        ])

        data = json.loads(result.stdout)
        mergeable = data.get("mergeable", "UNKNOWN")

        if mergeable == "CONFLICTING":
            return True, "PR has conflicts"
        elif mergeable == "MERGEABLE":
            return False, "PR has no conflicts"
        else:
            return False, f"PR merge status is {mergeable}"

    except subprocess.CalledProcessError:
        print_error(f"Could not check PR #{pr_number}")
        return False, "Could not determine PR status"

def main():
    """Main entry point"""
    parser = argparse.ArgumentParser(
        description="Resolve merge conflicts using LLM",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  %(prog)s
  %(prog)s --pr 67
  %(prog)s --dry-run --strategy smart
        """
    )

    parser.add_argument(
        "--pr",
        type=int,
        help="PR number to check and resolve conflicts for"
    )

    parser.add_argument(
        "--strategy",
        choices=["smart", "ours", "theirs"],
        default="smart",
        help="Conflict resolution strategy (default: smart)"
    )

    parser.add_argument(
        "--mode",
        choices=["solo", "ensemble", "challenger"],
        default="ensemble",
        help="Dev-AID orchestration mode (default: ensemble for accuracy)"
    )

    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Show proposed resolution without applying changes"
    )

    parser.add_argument(
        "--auto",
        action="store_true",
        help="Automatically apply resolution without confirmation"
    )

    parser.add_argument(
        "--verbose",
        action="store_true",
        help="Enable verbose output"
    )

    args = parser.parse_args()

    # Print header
    print()
    print_colored("=" * 70, Colors.BOLD)
    print_colored("  🔧 Dev-AID Conflict Resolver", Colors.BOLD)
    print_colored("=" * 70, Colors.BOLD)
    print()

    # Check for conflicts
    if args.pr:
        print_info(f"Checking PR #{args.pr} for conflicts...")
        has_conflicts, status = check_pr_conflicts(args.pr)
        print_info(status)

        if not has_conflicts:
            print_success("No conflicts to resolve!")
            return 0

    print_info("Detecting conflicts in current branch...")
    conflicted_files = detect_conflicts()

    if not conflicted_files:
        print_success("No conflicts detected!")
        return 0

    print()
    print_colored("📋 Conflicted Files:", Colors.BOLD)
    for file in conflicted_files:
        print(f"  - {file}")
    print()

    if len(conflicted_files) > 10:
        print_warning(f"Found {len(conflicted_files)} conflicted files - this may take a while")
        if not args.auto and not confirm_action("Continue with conflict resolution?", default=True):
            print_info("Cancelled by user")
            return 0

    # Process each conflicted file
    resolutions = {}

    for file_path in conflicted_files:
        print()
        print_colored(f"🔍 Analyzing: {file_path}", Colors.BOLD)
        print_colored("-" * 70, Colors.BOLD)

        # Read conflict content
        content = get_conflict_content(file_path)
        if not content:
            print_warning(f"Skipping {file_path} - no conflicts or cannot read")
            continue

        # Parse conflicts
        conflicts = parse_conflicts(content)
        if not conflicts:
            print_warning(f"Skipping {file_path} - could not parse conflicts")
            continue

        print_info(f"Found {len(conflicts)} conflict(s)")

        # Build prompt
        prompt = build_conflict_prompt(file_path, conflicts, args.strategy)

        if args.verbose:
            print()
            print_colored("📝 Prompt:", Colors.BOLD)
            print(prompt)
            print()

        # Execute LLM
        print_info(f"Resolving conflicts using {args.mode} mode...")

        try:
            result = execute_request(
                request=prompt,
                mode=args.mode,
                verbose=args.verbose
            )

            print()
            print_colored("💡 Proposed Resolution:", Colors.BOLD)
            print(result)
            print()

            resolutions[file_path] = result

        except Exception as e:
            print_error(f"Failed to generate resolution for {file_path}: {e}")
            continue

    if not resolutions:
        print_error("Could not generate any resolutions")
        return 1

    # Dry-run mode - stop here
    if args.dry_run:
        print_info("Dry-run mode - no changes applied")
        print_info("Remove --dry-run to apply resolutions")
        return 0

    # Apply resolutions
    print()
    print_colored("🚀 Applying Resolutions", Colors.BOLD)
    print_colored("-" * 70, Colors.BOLD)

    if not args.auto:
        if not confirm_action("Apply the proposed resolutions?", default=False):
            print_info("Cancelled by user")
            return 0

    applied_count = 0
    for file_path, resolution in resolutions.items():
        print_info(f"Applying resolution to {file_path}...")

        # Note: The LLM output may include explanations
        # In a production version, we'd parse the actual code from the response
        # For now, we'll show a message that manual application is needed
        print_warning("Automatic application requires parsing LLM output")
        print_info("Please review the proposed resolution and apply manually")
        applied_count += 1

    print()
    print_colored("💡 Next Steps:", Colors.CYAN)
    print("1. Review the proposed resolutions above")
    print("2. Manually apply the resolved code to the conflicted files")
    print("3. Mark conflicts as resolved: git add <file>")
    print("4. Continue the merge/rebase: git merge --continue or git rebase --continue")
    print("5. Run tests to verify: pytest or your test command")
    print()

    print_success(f"Generated resolutions for {applied_count} file(s)!")
    return 0

if __name__ == "__main__":
    try:
        sys.exit(main())
    except KeyboardInterrupt:
        print()
        print_warning("Cancelled by user")
        sys.exit(130)
    except Exception as e:
        print_error(f"Unexpected error: {e}")
        if "--verbose" in sys.argv:
            import traceback
            traceback.print_exc()
        sys.exit(1)

#!/bin/bash
# DevAID Local Search - User-friendly wrapper
# Wraps claude-context-local with DevAID branding
# Usage: devaid-search <command> [options]

# Colors
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

# Check if claude-context-local is installed
if ! command -v claude-context-local &> /dev/null; then
    echo -e "${RED}✗ DevAID Local Search is not installed${NC}"
    echo ""
    echo -e "${YELLOW}To install, run:${NC}"
    echo "  ./.dev-aid/scripts/setup-rag.sh"
    echo ""
    exit 1
fi

# If no arguments, show help
if [ $# -eq 0 ]; then
    echo -e "${BLUE}╔════════════════════════════════════════════╗${NC}"
    echo -e "${BLUE}║      DevAID Local Search                   ║${NC}"
    echo -e "${BLUE}╚════════════════════════════════════════════╝${NC}"
    echo ""
    echo -e "${GREEN}100% local semantic code search${NC}"
    echo -e "${BLUE}Powered by claude-context-local by FarhanAliRaza${NC}"
    echo ""
    echo -e "${YELLOW}Usage:${NC}"
    echo "  devaid-search index [path]    Index a directory"
    echo "  devaid-search search <query>  Search your code"
    echo "  devaid-search status          Show index status"
    echo "  devaid-search --version       Show version"
    echo ""
    echo -e "${YELLOW}Examples:${NC}"
    echo "  devaid-search index .         # Index current directory"
    echo "  devaid-search search 'auth'   # Find authentication code"
    echo ""
    echo -e "${YELLOW}Advanced:${NC}"
    echo "  claude-context-local <args>   # Use underlying tool directly"
    echo ""
    exit 0
fi

# Handle special commands
case "$1" in
    status)
        echo -e "${BLUE}DevAID Local Search Status${NC}"
        echo ""

        # Check version
        VERSION=$(claude-context-local --version 2>/dev/null || echo "unknown")
        echo -e "${GREEN}✓${NC} Installed: $VERSION"

        # Check index
        INDEX_DIR="$HOME/.claude_code_search/index"
        if [ -d "$INDEX_DIR" ]; then
            INDEX_SIZE=$(du -sh "$INDEX_DIR" 2>/dev/null | cut -f1)
            echo -e "${GREEN}✓${NC} Index size: $INDEX_SIZE"

            # Count projects
            PROJECT_COUNT=$(ls -1 "$INDEX_DIR" 2>/dev/null | wc -l)
            echo -e "${GREEN}✓${NC} Indexed projects: $PROJECT_COUNT"
        else
            echo -e "${YELLOW}⚠${NC} No index found"
            echo "  Run: devaid-search index ."
        fi

        # Check model
        MODEL_DIR="$HOME/.claude_code_search/models"
        if [ -d "$MODEL_DIR" ]; then
            MODEL_SIZE=$(du -sh "$MODEL_DIR" 2>/dev/null | cut -f1)
            echo -e "${GREEN}✓${NC} Model downloaded: $MODEL_SIZE"
        else
            echo -e "${YELLOW}⚠${NC} Model not downloaded"
        fi

        echo ""
        exit 0
        ;;

    index)
        echo -e "${BLUE}→ Indexing with DevAID Local Search...${NC}"
        echo ""
        claude-context-local "$@"
        echo ""
        echo -e "${GREEN}✓ Indexing complete${NC}"
        exit 0
        ;;

    search)
        echo -e "${BLUE}→ Searching with DevAID Local Search...${NC}"
        echo ""
        claude-context-local "$@"
        exit 0
        ;;

    --version|-v)
        echo -e "${BLUE}DevAID Local Search${NC}"
        claude-context-local --version
        echo ""
        echo -e "${BLUE}Powered by:${NC} claude-context-local by FarhanAliRaza"
        echo -e "${BLUE}Repository:${NC} github.com/FarhanAliRaza/claude-context-local"
        exit 0
        ;;

    *)
        # Pass through to claude-context-local
        claude-context-local "$@"
        exit $?
        ;;
esac

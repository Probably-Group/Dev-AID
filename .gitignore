# Dev-AID API Keys (NEVER commit these!)
.dev-aid/config/.env
.dev-aid/config/.env.*
!.dev-aid/config/.env.example
.dev-aid/config/backups/

# Logs and Runtime Files
.dev-aid/logs/*.log
.dev-aid/logs/*.log.*
.dev-aid/logs/costs.json
.dev-aid/logs/routing-history.json
.dev-aid/logs/rag-*.log

# Temporary files
.dev-aid/temp/*
!.dev-aid/temp/.gitkeep
temp/
*.backup
*.backup-*
*.backup-condense

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Provider symlinks (created during installation)
CLAUDE.md
GEMINI.md
OPENAI.md
OPENROUTER.md

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
.venv
.dev-aid/orchestration/.venv/

# Test coverage & caches
.coverage
coverage.xml
htmlcov/
.pytest_cache/
.mypy_cache/

# Core skills local overrides (personal preferences)
.dev-aid/config/core-skills.local.json

# Node.js (for TOON SDK)
node_modules/
package-lock.json
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Misc logs
talosboot.log
*.log

# Internal planning docs (not for public)
repo-migration-plan.md
docs/plans/

# Security scan results (generated by tools)
gitleaks-report.*
trivy-report.*
checkov-report.*
opengrep-results/
.scannerwork/

